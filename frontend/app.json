{
  "expo": {
    "name": "Overlap - Holiday Calendar",
    "slug": "overlap-holidays-2",
    "version": "2.0.20",
     "owner": "anadworld",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "overlap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
  "supportsTablet": true,
  "isTabletOnly": false,
  "bundleIdentifier": "app.emergent.vacationplanner489409be91",
  "infoPlist": {
    "ITSAppUsesNonExemptEncryption": false
  }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#E8567F"
      },
      "package": "com.anadworld.overlap"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A2E"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7C9CBF"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Overlap to access your calendar to add holiday events."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
   "extra": {
      "router": {},
      "eas": {
        "projectId": "5f5e1b9a-29c6-43cd-9e82-6fad22c661f2"
      }
    }
  }
}